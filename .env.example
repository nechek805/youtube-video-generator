#UV
HOME=/tmp
UV_CACHE_DIR=/tmp/uv-cache

#Postgres
DATABASE_URL=postgresql+asyncpg://postgres_user:postgres_password@postgres:5432/postgres_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=postgres_db
POSTGRES_USER=postgres_user
POSTGRES_PASSWORD=postgres_password

#Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

#LLM
# Active LLM provider: openai | mock (mock auto-selected when OPENAI_API_KEY is empty)
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
MOCK_VIDEO_CDN_BASE=https://mock-cdn.example.com/videos

#Video provider
# Active provider: mock | runway | pika | luma | kling
VIDEO_PROVIDER=mock
# Mock mode: placeholder (fake CDN URL) | static (BASE_URL/static/sample.mp4)
MOCK_VIDEO_MODE=placeholder
# Placeholder API keys for future provider integrations (paid APIs not wired yet)
RUNWAY_API_KEY=
PIKA_API_KEY=
LUMA_API_KEY=
KLING_API_KEY=

#Redis
REDIS_URL=redis://redis:6379/0

#Email (SMTP / Gmail fallback)
SENDER_EMAIL=example@mail.com
EMAIL_APP_PASSWORD=12341451

#Resend
RESEND_API_KEY=re_your_api_key_here

#App
BASE_URL=http://localhost:8000
ORIGINS=["http://localhost:3000"]
HTTPS_REDIRECT=false
